# Help Scout
HELPSCOUT_APP_ID=your_helpscout_app_id
HELPSCOUT_APP_SECRET=your_helpscout_app_secret
HELPSCOUT_API_URL=https://api.helpscout.net/v2
HELPSCOUT_WEBHOOK_SECRET=your_webhook_secret_from_helpscout

# AI
AI_API_TYPE=groq
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TRANSLATE_MODEL=llama-3.1-8b-instant

# Language detection (optional; if unset, fasttext LID model is downloaded to ~/.cache/sovware-support-manager)
# FASTTEXT_LID_MODEL=/path/to/lid.176.ftz

# Database (optional when DB is disabled)
# DATABASE_URL=postgresql://user:password@localhost:5432/sovware_support

# App
APP_NAME=SovWare Support Management
DEBUG=True
